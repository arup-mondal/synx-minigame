# Syndicate Protocol API base (optional override)
NEXT_PUBLIC_SYNDICATE_API_URL=https://syndicate-protocol.com

# Where to send users who open Dead Drop outside the main game iframe
NEXT_PUBLIC_MAIN_GAME_URL=https://syndicate-protocol.com/game

# Origins allowed to embed Dead Drop in an iframe (space/comma separated)
DEAD_DROP_FRAME_ANCESTORS=https://syndicate-protocol.com https://www.syndicate-protocol.com

# Origins allowed for CORS on /api/* (comma/space separated)
DEAD_DROP_CORS_ORIGINS=https://syndicate-protocol.com,https://www.syndicate-protocol.com

# Origins trusted for postMessage player handoff (client-side)
NEXT_PUBLIC_DEAD_DROP_PARENT_ORIGINS=https://syndicate-protocol.com,https://www.syndicate-protocol.com